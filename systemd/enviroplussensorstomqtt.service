# systemd unit file for the Python Demo Service


[Unit]

# Human readable name of the unit
Description=Sense hat sensors to MQTT
After=network.target
Wants=network.target

[Service]
#Type=forking
Type=simple
RemainAfterExit=yes
Restart=always
RestartSec=3

# Command to execute when the service is started
ExecStart=/usr/local/bin/enviroplussensorstomqtt
#ExecStop=pkill -F /run/enviroplussensorstomqtt/enviroplussensorstomqtt.pid

# Disable Python's buffering of STDOUT and STDERR, so that output from the
# service shows up immediately in systemd's logs
Environment=PYTHONUNBUFFERED=1

# Automatically restart the service if it crashes
Restart=on-failure

#StandardInput=tty-force

# Use a dedicated user to run our service
User=root
Group=root

#PIDFile=/run/enviroplussensorstomqtt/enviroplussensorstomqtt.pid
StandardOutput=journal

TimeoutStartSec=600

[Install]

# Tell systemd to automatically start this service when the system boots
# (assuming the service is enabled)
WantedBy=multi-user.target
